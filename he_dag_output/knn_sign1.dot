digraph he_dag {
  rankdir=LR;
  graph [fontname="Helvetica"];
  node [shape=box, style="rounded,filled", fontname="Helvetica"];
  edge [fontname="Helvetica"];
  subgraph cluster_layer_0 {
    label="layer 0";
    color="#cccccc";
    op0 [label="op0\nassign\nline 349\ncost 1\nout ciph_result@1\nin ciph@0", fillcolor="#17becf"];
  }
  subgraph cluster_layer_1 {
    label="layer 1";
    color="#cccccc";
    op1 [label="op1\nevaluate_poly_vector\nline 350\ncost 8\nout ciph_result@2\nin ciph_result@1", fillcolor="#e377c2"];
  }
  subgraph cluster_layer_2 {
    label="layer 2";
    color="#cccccc";
    op2 [label="op2\nevaluate_poly_vector\nline 351\ncost 8\nout ciph_result@3\nin ciph_result@2", fillcolor="#e377c2"];
  }
  subgraph cluster_layer_3 {
    label="layer 3";
    color="#cccccc";
    op3 [label="op3\nadd_const\nline 352\ncost 1\nout ciph_result@4\nin ciph_result@3", fillcolor="#dddddd"];
  }
  op0 -> op1 [color="#222222", label="ciph_result"];
  op0 -> op1 [color="#d62728", label="overwrite ciph_result"];
  op1 -> op2 [color="#222222", label="ciph_result"];
  op1 -> op2 [color="#d62728", label="overwrite ciph_result"];
  op2 -> op3 [color="#222222", label="ciph_result"];
  op2 -> op3 [color="#d62728", label="overwrite ciph_result"];
}
