digraph he_dag {
  rankdir=LR;
  graph [fontname="Helvetica"];
  node [shape=box, style="rounded,filled", fontname="Helvetica"];
  edge [fontname="Helvetica"];
  subgraph cluster_layer_0 {
    label="layer 0";
    color="#cccccc";
    op0 [label="op0\nsub\nline 254\ncost 1\nout ciph_data[i]@1\nin ciph_data[i]@0, ciph_query[i]@0", fillcolor="#2ca02c"];
    op1 [label="op1\nsub\nline 257\ncost 1\nout ciph_data[i + 10]@1\nin ciph_data[i + 10]@0, ciph_query[i]@0", fillcolor="#2ca02c"];
  }
  subgraph cluster_layer_1 {
    label="layer 1";
    color="#cccccc";
    op2 [label="op2\nmultiply_relin\nline 259\ncost 6\nout ciph_data[i]@2\nin ciph_data[i]@1, ciph_data[i]@1", fillcolor="#d62728"];
  }
  subgraph cluster_layer_2 {
    label="layer 2";
    color="#cccccc";
    op4 [label="op4\nmultiply_relin\nline 262\ncost 6\nout ciph_data[i + 10]@2\nin ciph_data[i + 10]@1, ciph_data[i + 10]@1", fillcolor="#d62728"];
  }
  subgraph cluster_layer_3 {
    label="layer 3";
    color="#cccccc";
    op3 [label="op3\nrescale_dynamic\nline 260\ncost 4\nout ciph_data[i]@3\nin ciph_data[i]@2", fillcolor="#8c564b"];
  }
  subgraph cluster_layer_4 {
    label="layer 4";
    color="#cccccc";
    op5 [label="op5\nrescale_dynamic\nline 263\ncost 4\nout ciph_data[i + 10]@3\nin ciph_data[i + 10]@2", fillcolor="#8c564b"];
  }
  op0 -> op2 [color="#222222", label="ciph_data[i]"];
  op0 -> op2 [color="#222222", label="ciph_data[i]"];
  op0 -> op2 [color="#d62728", label="overwrite ciph_data[i]"];
  op2 -> op3 [color="#222222", label="ciph_data[i]"];
  op2 -> op3 [color="#d62728", label="overwrite ciph_data[i]"];
  op1 -> op4 [color="#222222", label="ciph_data[i + 10]"];
  op1 -> op4 [color="#222222", label="ciph_data[i + 10]"];
  op1 -> op4 [color="#d62728", label="overwrite ciph_data[i + 10]"];
  op4 -> op5 [color="#222222", label="ciph_data[i + 10]"];
  op4 -> op5 [color="#d62728", label="overwrite ciph_data[i + 10]"];
}
