digraph he_dag {
  rankdir=LR;
  graph [fontname="Helvetica"];
  node [shape=box, style="rounded,filled", fontname="Helvetica"];
  edge [fontname="Helvetica"];
  subgraph cluster_layer_0 {
    label="layer 0";
    color="#cccccc";
    op0 [label="op0\nsub\nline 13\ncost 1\nout diff0@1", fillcolor="#2ca02c"];
    op1 [label="op1\nsub\nline 14\ncost 1\nout diff1@1", fillcolor="#2ca02c"];
  }
  subgraph cluster_layer_1 {
    label="layer 1";
    color="#cccccc";
    op2 [label="op2\nmultiply\nline 15\ncost 5\nout sq0@1\nin diff0@1, diff0@1", fillcolor="#d62728"];
    op3 [label="op3\nmultiply\nline 16\ncost 5\nout sq1@1\nin diff1@1, diff1@1", fillcolor="#d62728"];
  }
  subgraph cluster_layer_2 {
    label="layer 2";
    color="#cccccc";
    op4 [label="op4\nrotate\nline 17\ncost 4\nout rot0@1\nin sq0@1", fillcolor="#9467bd"];
  }
  subgraph cluster_layer_3 {
    label="layer 3";
    color="#cccccc";
    op5 [label="op5\nadd\nline 18\ncost 1\nout total@1\nin rot0@1, sq1@1", fillcolor="#2ca02c"];
  }
  op0 -> op2 [color="#222222", label="diff0"];
  op0 -> op2 [color="#222222", label="diff0"];
  op1 -> op3 [color="#222222", label="diff1"];
  op1 -> op3 [color="#222222", label="diff1"];
  op2 -> op4 [color="#222222", label="sq0"];
  op4 -> op5 [color="#222222", label="rot0"];
  op3 -> op5 [color="#222222", label="sq1"];
}
