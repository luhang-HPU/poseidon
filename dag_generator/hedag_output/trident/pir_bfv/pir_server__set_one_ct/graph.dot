  }
  subgraph cluster_layer_2 {
    label="layer 2";
    color="#d1d5db";
    op2 [label="op2\nassign\nline 604\nlayer 2\ncost 1\nout one_@2\nin tmp@1", fillcolor="#17becf"];
  }
  op0 -> op1 [color="#1f2937", label="one_"];
  op0 -> op1 [color="#2563eb", label="one_"];
  op1 -> op2 [color="#1f2937", label="tmp"];
  op1 -> op2 [color="#2563eb", label="tmp"];
