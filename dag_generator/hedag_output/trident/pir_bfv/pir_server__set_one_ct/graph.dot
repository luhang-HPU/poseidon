digraph hedag_v2 {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Helvetica"];
  edge [fontname="Helvetica"];
  subgraph cluster_layer_0 {
    label="layer 0";
    color="#d1d5db";
    op0 [label="op0\nassign\nline 601\nlayer 0\ncost 1\nout one_@1\nin one@0", fillcolor="#17becf"];
  }
  subgraph cluster_layer_1 {
    label="layer 1";
    color="#d1d5db";
