digraph hedag_v2 {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Helvetica"];
  edge [fontname="Helvetica"];
  subgraph cluster_layer_0 {
    label="layer 0";
    color="#d1d5db";
    op0 [label="op0\nadd\nline 1303\nlayer 0\ncost 1\nout felt_item@1", fillcolor="#e5e7eb"];
