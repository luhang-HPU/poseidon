  subgraph cluster_layer_1 {
    label="layer 1";
    color="#d1d5db";
    op1 [label="op1\nreturn\nline 1309\nlayer 1\ncost 1\nout __return__@1\nin felt_item@1", fillcolor="#64748b"];
  }
  op0 -> op1 [color="#1f2937", label="felt_item"];
  op0 -> op1 [color="#2563eb", label="felt_item"];
}
